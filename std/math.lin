    inputs:  [a [i64!] b [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.add %a, %b : i64
}

sub64: mlir-op [
    inputs:  [a [i64!] b [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.sub %a, %b : i64
}

