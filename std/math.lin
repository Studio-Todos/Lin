not: mlir-op [
    inputs:  [a [i32!]]
    outputs: [res [i32!]]
] {
    %neg1 = llvm.mlir.constant(-1 : i32) : i32
    %res = llvm.xor %a, %neg1 : i32
}

not64: mlir-op [
    inputs:  [a [i64!]]
    outputs: [res [i64!]]
] {
    %neg1 = llvm.mlir.constant(-1 : i64) : i64
    %res = llvm.xor %a, %neg1 : i64
}

ctlz: mlir-op [
    inputs:  [a [i32!]]
    outputs: [res [i32!]]
] {
    %res = llvm.intr.ctlz(%a) <{is_zero_undef = false}> : (i32) -> i32
}

cttz: mlir-op [
    inputs:  [a [i32!]]
    outputs: [res [i32!]]
] {
    %res = llvm.intr.cttz(%a) <{is_zero_undef = false}> : (i32) -> i32
}

ctpop: mlir-op [
    inputs:  [a [i32!]]
    outputs: [res [i32!]]
] {
    %res = llvm.intr.ctpop(%a) : (i32) -> i32
}

ctlz64: mlir-op [
    inputs:  [a [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.intr.ctlz(%a) <{is_zero_undef = false}> : (i64) -> i64
}

cttz64: mlir-op [
    inputs:  [a [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.intr.cttz(%a) <{is_zero_undef = false}> : (i64) -> i64
}

ctpop64: mlir-op [
    inputs:  [a [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.intr.ctpop(%a) : (i64) -> i64
}

