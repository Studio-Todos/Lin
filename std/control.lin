// std/control.lin
// Standard control flow logic using strict parallel dataflow structures.

either: mlir-op [
    inputs:  [cond [i32!] t [i32!] f [i32!]]
    outputs: [res [i32!]]
] {
    %c0 = llvm.mlir.constant(0 : i32) : i32
    %cond_bool = llvm.icmp "ne" %cond, %c0 : i32
    %res = llvm.select %cond_bool, %t, %f : i1, i32
}
