// RUN: %linc build %s -o %t && %t

import "std/file.lin"
import "std/mem.lin"
import "std/math.lin"

test_file_more: func [
    argc [i32!]
    return: [i32!]
][
    state: 0

    // create filename "test_more.txt\0"
    s1_fn_ptr: (malloc state 14)
    s2: (store_i8 s1_fn_ptr.0 s1_fn_ptr.1 116) // t
    s3: (store_i8 s2.0 (add s1_fn_ptr.1 1) 101) // e
    s4: (store_i8 s3.0 (add s1_fn_ptr.1 2) 115) // s
    s5: (store_i8 s4.0 (add s1_fn_ptr.1 3) 116) // t
    s6: (store_i8 s5.0 (add s1_fn_ptr.1 4) 95) // _
    s7: (store_i8 s6.0 (add s1_fn_ptr.1 5) 109) // m
    s8: (store_i8 s7.0 (add s1_fn_ptr.1 6) 111) // o
    s9: (store_i8 s8.0 (add s1_fn_ptr.1 7) 114) // r
    s10: (store_i8 s9.0 (add s1_fn_ptr.1 8) 101) // e
    s11: (store_i8 s10.0 (add s1_fn_ptr.1 9) 46) // .
    s12: (store_i8 s11.0 (add s1_fn_ptr.1 10) 116) // t
    s13: (store_i8 s12.0 (add s1_fn_ptr.1 11) 120) // x
    s14: (store_i8 s13.0 (add s1_fn_ptr.1 12) 116) // t
    s15: (store_i8 s14.0 (add s1_fn_ptr.1 13) 0) // \0

    // mode "w\0"
    w_md_ptr: (malloc s15.0 2)
    s16: (store_i8 w_md_ptr.0 w_md_ptr.1 119) // w
    s17: (store_i8 s16.0 (add w_md_ptr.1 1) 0)

    file_w_ptr: (fopen s17.0 s1_fn_ptr.1 w_md_ptr.1)

    // write 'Z'
    s18: (fputc file_w_ptr.0 90 file_w_ptr.1)

    s19: (fclose s18.0 file_w_ptr.1)

    // mode "r\0"
    r_md_ptr: (malloc s19.0 2)
    s20: (store_i8 r_md_ptr.0 r_md_ptr.1 114) // r
    s21: (store_i8 s20.0 (add r_md_ptr.1 1) 0)

    file_r_ptr: (fopen s21.0 s1_fn_ptr.1 r_md_ptr.1)

    res_c: (fgetc file_r_ptr.0 file_r_ptr.1)

    s22: (fclose res_c.0 file_r_ptr.1)

    s23: (free s22.0 s1_fn_ptr.1)
    s24: (free s23.0 w_md_ptr.1)
    s25: (free s24.0 r_md_ptr.1)

    either (eq res_c.1 90) [
        0 // ok
    ][
        1 // fail
    ]
]
