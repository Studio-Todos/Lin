// RUN: %linc build %s -o %t | FileCheck %s

import "std/mem.lin"

// CHECK: Parsing Source:
// CHECK: Generated MLIR

test_mem: func [
    argc [i32!]
    return: [i32!]
][
    state: 0

    // Allocate 4 bytes
    st1_ptr: (malloc state 4)
    // Store 42 into it
    st2: (store_i32 st1_ptr.0 st1_ptr.1 42)
    // Load it back
    st3_val: (load_i32 st2.0 st1_ptr.1)
    // Free it
    st4: (free st3_val.0 st1_ptr.1)

    st3_val.1
]
