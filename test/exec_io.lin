// RUN: %linc build %s -o %t && echo "123" | %t
// RUN: %linc build %s --gpu -o %t_gpu && test -s %t_gpu.spv && spirv-val %t_gpu.spv

import "std/io.lin"

test_io_funcs: func [
    argc [i32!]
    return: [i32!]
][
    state: 0
    state: (print_i32 state 42)
    state: (print_char state 10)
    state: (read_i32 state)
    0
]
