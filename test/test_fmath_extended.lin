// RUN: %linc build %s -o test_fmath_extended_bin | FileCheck %s
// RUN: %linc build %s --gpu -o test_fmath_extended_bin_gpu | FileCheck %s --check-prefix=GPU
// RUN: test -s test_fmath_extended_bin_gpu.spv
// RUN: spirv-val test_fmath_extended_bin_gpu.spv

// CHECK: Parsing Source:
// CHECK: test_fmath_ext: func [
// CHECK: Generated MLIR (before lowering):
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fadd", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fsub", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fmul", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fdiv", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "frem", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "flt", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fgt", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fle", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fge", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "feq", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "fneq", polarity = "-"}>

// GPU: Parsing Source:
// GPU: test_fmath_ext: func [
// GPU: Generated MLIR (before lowering):
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fadd", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fsub", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fmul", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fdiv", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "frem", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "flt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fgt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fle", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fge", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "feq", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "fneq", polarity = "-"}>


import "std/math.lin"

test_fmath_ext: func [
    n [f32!]
    return: [f32!]
][
    (fadd n n)
    (fsub n n)
    (fmul n n)
    (fdiv n n)
    (frem n n)
    (flt n n)
    (fgt n n)
    (fle n n)
    (fge n n)
    (feq n n)
    (fneq n n)
    n
]
