// RUN: %linc build %s -o %t && %t
// RUN: %linc build %s --gpu -o %t_gpu && test -s %t_gpu.spv && spirv-val %t_gpu.spv

import "std/math.lin"

test_math64: func [
    argc [i32!]
    return: [i32!]
][
    either (neq64 (add64 10 5) 15) [
        1
    ][
        either (neq64 (sub64 10 5) 5) [
            2
        ][
            either (neq64 (mul64 10 5) 50) [
                3
            ][
                either (neq64 (div64 10 5) 2) [
                    4
                ][
                    either (neq64 (rem64 10 3) 1) [
                        5
                    ][
                        0
                    ]
                ]
            ]
        ]
    ]
]
