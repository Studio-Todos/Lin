// test_queue_safety.lin
// A4b: Queue atomicity — verifies compiler correctly lowers a program with
// recursive calls that generate many active pairs (stresses the redex queue).
// RUN: %linc build %s -o %t
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: Successfully compiled and linked to

let add_i32 = @[add_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.addi %x, %y : i32
    lin.coerce %res : i32 to i64
}

let sum_to = fn(n) {
    if n == 0 then 0
    else n + sum_to(n - 1)
}

print(sum_to(4))
