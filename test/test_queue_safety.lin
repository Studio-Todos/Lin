// test_queue_safety.lin
// A4b: Queue atomicity — verifies compiler correctly lowers a program with
// recursive calls that generate many active pairs (stresses the redex queue).
// RUN: %linc build %s -o %t 2>&1 | FileCheck %s
// CHECK: Lowering pass successful.
// CHECK: Successfully compiled and linked to

import "std/math.lin"

sum_to: func [n [i32!] return: [i32!]] [
    either (eq n 0) [0] [(add n (sum_to (sub n 1)))]
]

(sum_to 4)