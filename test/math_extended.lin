// RUN: %linc build %s -o test_math_ext_bin | FileCheck %s
// RUN: %linc build %s --gpu -o test_math_ext_bin_gpu | FileCheck %s --check-prefix=GPU

// CHECK: Parsing Source:
// CHECK: test_math_ext: func [
// CHECK: Generated MLIR (before lowering):
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "rem", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "lt", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "gt", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "le", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "ge", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "eq", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "neq", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "shl", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "shr", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "and", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "or", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "xor", polarity = "-"}>

// GPU: Parsing Source:
// GPU: test_math_ext: func [
// GPU: Generated MLIR (before lowering):
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "rem", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "lt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "gt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "le", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "ge", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "eq", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "neq", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "shl", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "shr", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "and", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "or", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "xor", polarity = "-"}>

import "std/math.lin"

test_math_ext: func [
    n [i32!]
    return: [i32!]
][
    (rem n n)
    (lt n n)
    (gt n n)
    (le n n)
    (ge n n)
    (eq n n)
    (neq n n)
    (shl n n)
    (shr n n)
    (and n n)
    (or n n)
    (xor n n)
    n
]
