// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "gt", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "le", polarity = "-"}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "ge", polarity = "-"}>
