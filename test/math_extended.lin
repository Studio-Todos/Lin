// GPU: Parsing Source:
// GPU: test_math: func [
// GPU: Generated MLIR (before lowering):
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "add", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "sub", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "mul", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "div", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "rem", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "lt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "gt", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "le", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "ge", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "eq", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "neq", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "shl", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "shr", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "and", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "or", polarity = "-"}>
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "xor", polarity = "-"}>

import "std/math.lin"

test_math: func [
    n [i32!]
    return: [i32!]
][
    (add n 1)
    (sub n 1)
    (mul n 2)
    (div n 2)
    (rem n 3)
    (lt n 4)
    (gt n 5)
    (le n 6)
    (ge n 7)
    (eq n 8)
    (neq n 9)
    (shl n 1)
    (shr n 1)
    (and n 1)
    (or n 1)
    (xor n 1)
    n
]
