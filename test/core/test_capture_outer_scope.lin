// Tests: Capture outer scope in nested function
// RUN: %linc build %s -o %t
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: Successfully compiled and linked to

import "std/types.lin"

make_counter: func [start [i32!]] [
    count: start
    next: func [return: [i32!]] [
        count: count + 1
        count
    ]
    next
]

next_counter: (make_counter 0)
(next_counter)