// RUN: %linc build %s -o %t | FileCheck %s

import "std/file.lin"
import "std/mem.lin"

// CHECK: Parsing Source:
// CHECK: Generated MLIR

add64: mlir-op [
    inputs:  [a [i64!] b [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.add %a, %b : i64
}

test_file: func [
    argc [i32!]
    return: [i32!]
][
    state: 0

    // We allocate 16 bytes for filename, write "test.txt\0"
    s1_fn_ptr: (malloc state 16)
    s2: (store_i8 s1_fn_ptr.0 s1_fn_ptr.1 116)
    idx1: (add64 s1_fn_ptr.1 1)
    s3: (store_i8 s2.0 idx1.0 101)
    idx2: (add64 s1_fn_ptr.1 2)
    s4: (store_i8 s3.0 idx2.0 115)
    idx3: (add64 s1_fn_ptr.1 3)
    s5: (store_i8 s4.0 idx3.0 116)
    idx4: (add64 s1_fn_ptr.1 4)
    s6: (store_i8 s5.0 idx4.0 46)
    idx5: (add64 s1_fn_ptr.1 5)
    s7: (store_i8 s6.0 idx5.0 116)
    idx6: (add64 s1_fn_ptr.1 6)
    s8: (store_i8 s7.0 idx6.0 120)
    idx7: (add64 s1_fn_ptr.1 7)
    s9: (store_i8 s8.0 idx7.0 116)
    idx8: (add64 s1_fn_ptr.1 8)
    s10: (store_i8 s9.0 idx8.0 0)

    // We allocate 4 bytes for mode "w\0"
    s11_md_ptr: (malloc s10.0 4)
    s12: (store_i8 s11_md_ptr.0 s11_md_ptr.1 119)
    id_md: (add64 s11_md_ptr.1 1)
    s13: (store_i8 s12.0 id_md.0 0)

    // fopen
    s14_file_ptr: (fopen s13.0 s1_fn_ptr.1 s11_md_ptr.1)

    // free filename and mode
    s15: (free s14_file_ptr.0 s11_md_ptr.1)
    s16: (free s15.0 s1_fn_ptr.1)

    0
]
