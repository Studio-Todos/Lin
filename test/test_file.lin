// RUN: %linc build %s -o %t | FileCheck %s

import "std/file.lin"
import "std/mem.lin"

// CHECK: Parsing Source:
// CHECK: Generated MLIR

add64: mlir-op [
    inputs:  [a [i64!] b [i64!]]
    outputs: [res [i64!]]
] {
    %res = llvm.add %a, %b : i64
}

test_file: func [
    state [i64!]
    return: [i32!]
][
    // We allocate 16 bytes for filename, write "test.txt\0"
    let s1_fn_ptr (malloc state 16)
    let s2 (store_i8 s1_fn_ptr.0 s1_fn_ptr.1 116)
    let idx1 (add64 s1_fn_ptr.1 1)
    let s3 (store_i8 s2.0 idx1.0 101)
    let idx2 (add64 s1_fn_ptr.1 2)
    let s4 (store_i8 s3.0 idx2.0 115)
    let idx3 (add64 s1_fn_ptr.1 3)
    let s5 (store_i8 s4.0 idx3.0 116)
    let idx4 (add64 s1_fn_ptr.1 4)
    let s6 (store_i8 s5.0 idx4.0 46)
    let idx5 (add64 s1_fn_ptr.1 5)
    let s7 (store_i8 s6.0 idx5.0 116)
    let idx6 (add64 s1_fn_ptr.1 6)
    let s8 (store_i8 s7.0 idx6.0 120)
    let idx7 (add64 s1_fn_ptr.1 7)
    let s9 (store_i8 s8.0 idx7.0 116)
    let idx8 (add64 s1_fn_ptr.1 8)
    let s10 (store_i8 s9.0 idx8.0 0)

    // We allocate 4 bytes for mode "w\0"
    let s11_md_ptr (malloc s10.0 4)
    let s12 (store_i8 s11_md_ptr.0 s11_md_ptr.1 119)
    let id_md (add64 s11_md_ptr.1 1)
    let s13 (store_i8 s12.0 id_md.0 0)

    // fopen
    let s14_file_ptr (fopen s13.0 s1_fn_ptr.1 s11_md_ptr.1)

    // free filename and mode
    let s15 (free s14_file_ptr.0 s11_md_ptr.1)
    let s16 (free s15.0 s1_fn_ptr.1)

    0
]
