// RUN: %linc build %s -S -o %t | FileCheck %s
// RUN: %linc build %s --gpu -S -o %t_gpu | FileCheck %s --check-prefix=GPU
// RUN: test -s %t_gpu.spv
// RUN: spirv-val %t_gpu.spv

import "std/io.lin"
import "std/sys.lin"

// CHECK: module
// CHECK: llvm.func @printf
// CHECK: llvm.func @putchar
// CHECK: llvm.func @getchar
// CHECK: llvm.func @scanf
// CHECK: llvm.func @exit

// GPU: module
// GPU: llvm.func @printf
// GPU: llvm.func @putchar
// GPU: llvm.func @getchar
// GPU: llvm.func @scanf
// GPU: llvm.func @exit
