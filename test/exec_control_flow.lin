// RUN: %linc build %s -o %t && %t
// RUN: %linc build %s --gpu -o %t_gpu && test -s %t_gpu.spv

import "std/math.lin"
import "std/io.lin"

test_flow: func [
    argc [i32!]
    return: [i32!]
][
    state: 0
    cond: (lt 10 5)

    either cond [
        state: (print_i32 state 1)
    ][
        state: (print_i32 state 0)
    ]

    0
]
