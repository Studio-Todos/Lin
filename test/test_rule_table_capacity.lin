// test_rule_table_capacity.lin
// A2b: Rule table — multiple user ops must all be registered and dispatchable.
// Verifies the lookup_rule chain handles several distinct operations correctly.
// RUN: %linc build %s -o %t 2>&1 | FileCheck %s
// CHECK: Lowering pass successful.
// CHECK: Successfully compiled and linked to

let add_i32 = @[add_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.addi %x, %y : i32
    lin.coerce %res : i32 to i64
}
let mul_i32 = @[mul_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.muli %x, %y : i32
    lin.coerce %res : i32 to i64
}
let sub_i32 = @[sub_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.subi %x, %y : i32
    lin.coerce %res : i32 to i64
}
let divs_i32 = @[divs_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.divsi %x, %y : i32
    lin.coerce %res : i32 to i64
}
let rems_i32 = @[rems_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.remsi %x, %y : i32
    lin.coerce %res : i32 to i64
}

print(add_i32(7, 8))
print(mul_i32(10, 10))
print(rems_i32(10, 3))
