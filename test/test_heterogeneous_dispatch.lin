// RUN: %linc build %s -o %t_het && test -s %t_het.spv && spirv-val %t_het.spv
import "std/math.lin"
import "std/io.lin"

@gpu
gpu_func: func [
    dummy [i32!]
    return: [i32!]
][
    (add 10 20)
]

@cpu
cpu_func: func [
    dummy [i32!]
    return: [i32!]
][
    (add 5 5)
]

test_main: func [
    dummy [i32!]
    return: [i32!]
][
    x: (gpu_func 0)
    y: (cpu_func 0)
    (add x y)
]

(print_i32 (test_main 0))
