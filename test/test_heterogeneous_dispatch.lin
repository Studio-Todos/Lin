// RUN: %linc build %s -o %t_het | FileCheck %s
// RUN: %linc build %s --gpu -o %t_gpu | FileCheck %s --check-prefix=GPU
// RUN: test -s %t_gpu.spv
// RUN: spirv-val %t_gpu.spv

// CHECK: Parsing Source:
// CHECK: gpu_func: func [
// CHECK: cpu_func: func [
// CHECK: test_main: func [

// GPU: Parsing Source:
// GPU: gpu_func: func [
// GPU: cpu_func: func [
// GPU: test_main: func [

import "std/math.lin"
import "std/io.lin"

@gpu
gpu_func: func [
    dummy [i32!]
    return: [i32!]
][
    (add 10 20)
]

@cpu
cpu_func: func [
    dummy [i32!]
    return: [i32!]
][
    (add 5 5)
]

test_main: func [
    dummy [i32!]
    return: [i32!]
][
    x: (gpu_func 0)
    y: (cpu_func 0)
    (add x y)
]

(print_i32 (test_main 0))