// RUN: %linc build %s -o %t
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: Successfully compiled and linked to

// Tests: Function chaining — the output of one function call is passed
// as the input to another. In interaction net terms, the result port of
// the first call agent is wired to the arg port of the second.

import "std/types.lin"

inc: func [x [i32!] return: [i32!]] [x + 1]

dbl: func [x [i32!] return: [i32!]] [x + x]

; Chain: dbl(inc(3)) should give 8
step1: (inc 3)
step2: (dbl step1)
step2
