// test_closure_capture_add.lin
// Item 4c: findFreeVars fix — a closure must correctly capture a locally-bound
// name regardless of whether it happens to match a formerly-hardcoded builtin.
// RUN: %linc build %s -o %t
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: Successfully compiled and linked to

let add_i32 = @[add_i32] [inputs: [x [i32] y [i32]]] {
    %res = arith.addi %x, %y : i32
    lin.coerce %res : i32 to i64
}

// A function that takes an operation and applies it to two numbers
let apply = fn(f, a, b) { f(a, b) }

// Pass add_i32 as a first-class value through a closure
print(apply(add_i32, 2, 3))
