// RUN: %lin build %s -o test_fib_bin | FileCheck %s

// CHECK: Parsing Source:
// CHECK: fib: func [
// CHECK: Generated MLIR (before lowering):
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "num", polarity = "+", value = 2 : i32}>
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "lt", polarity = "-"}>
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: llvm.call @inet_init
// CHECK: Successfully compiled and linked to 'test_fib_bin'

fib: func [
    n [i32!]
    return: [i32!]
][
    either n < 2 [
        n
    ][
        (fib n - 1) + (fib n - 2)
    ]
]
