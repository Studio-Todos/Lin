// RUN: %linc build %s -o test_fib_bin | FileCheck %s
// RUN: %linc build %s --gpu -o test_fib_bin_gpu | FileCheck %s --check-prefix=GPU

// CHECK: Parsing Source:
// CHECK: fib: func [
// CHECK: Generated MLIR (before lowering):
// CHECK: "pic_graph.agent"() <{agentType = "epsilon", label = "era", polarity = "*"}>
// CHECK: Lowering pass successful. Generated LLVM IR:
// CHECK: llvm.call @malloc
// CHECK: Successfully compiled and linked to 'test_fib_bin'

// GPU: Parsing Source:
// GPU: fib: func [
// GPU: Generated MLIR (before lowering):
// GPU: "pic_graph.agent"() <{agentType = "epsilon", label = "era", polarity = "*"}>
// GPU: Lowering pass successful. Generated LLVM IR:
// GPU: Emitted SPIR-V module to test_fib_bin_gpu.spv
// GPU: Successfully compiled and linked to 'test_fib_bin_gpu'

import "std/math.lin"

fib: func [
    n [i32!]
    return: [i32!]
][
    either n < 2 [
        n
    ][
        (fib n - 1) + (fib n - 2)
    ]
]
