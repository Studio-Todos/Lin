// RUN: %linc build %s -o fib_test | FileCheck %s
// RUN: %linc build %s --gpu -o fib_test_gpu | FileCheck %s --check-prefix=GPU

// CHECK: Parsing Source:
// CHECK: fib: func [
// CHECK: Generated MLIR (before lowering):
// CHECK: "pic_graph.agent"() <{agentType = "omega", label = "add", polarity = "-"}>

// GPU: Parsing Source:
// GPU: fib: func [
// GPU: Generated MLIR (before lowering):
// GPU: "pic_graph.agent"() <{agentType = "omega", label = "add", polarity = "-"}>

fib: func [
    n [i32!]
    return: [i32!]
][
    either n < 2 [
        n
    ][
        (fib n - 1) + (fib n - 2)
    ]
]
