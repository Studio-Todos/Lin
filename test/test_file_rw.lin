// RUN: %linc build %s -o %t && %t

import "std/file.lin"
import "std/mem.lin"
import "std/math.lin"

// Simple test for file writing and reading back a character
test_file_rw: func [
    argc [i32!]
    return: [i32!]
][
    state: 0

    // 1. Allocate filename "test_rw.txt\0"
    fn_ptr: (malloc state 16)
    s2: (store_i8 fn_ptr.0 fn_ptr.1 116) // 't'
    idx1: (add64 fn_ptr.1 1)
    s3: (store_i8 s2.0 idx1.0 101) // 'e'
    idx2: (add64 fn_ptr.1 2)
    s4: (store_i8 s3.0 idx2.0 115) // 's'
    idx3: (add64 fn_ptr.1 3)
    s5: (store_i8 s4.0 idx3.0 116) // 't'
    idx4: (add64 fn_ptr.1 4)
    s6: (store_i8 s5.0 idx4.0 95)  // '_'
    idx5: (add64 fn_ptr.1 5)
    s7: (store_i8 s6.0 idx5.0 114) // 'r'
    idx6: (add64 fn_ptr.1 6)
    s8: (store_i8 s7.0 idx6.0 119) // 'w'
    idx7: (add64 fn_ptr.1 7)
    s9: (store_i8 s8.0 idx7.0 46)  // '.'
    idx8: (add64 fn_ptr.1 8)
    s10: (store_i8 s9.0 idx8.0 116) // 't'
    idx9: (add64 fn_ptr.1 9)
    s11: (store_i8 s10.0 idx9.0 120) // 'x'
    idx10: (add64 fn_ptr.1 10)
    s12: (store_i8 s11.0 idx10.0 116) // 't'
    idx11: (add64 fn_ptr.1 11)
    s13: (store_i8 s12.0 idx11.0 0)   // '\0'

    // 2. Allocate mode "w\0"
    w_md_ptr: (malloc s13.0 4)
    s14: (store_i8 w_md_ptr.0 w_md_ptr.1 119) // 'w'
    id_w: (add64 w_md_ptr.1 1)
    s15: (store_i8 s14.0 id_w.0 0) // '\0'

    // 3. Open file for writing
    file_w_ptr: (fopen s15.0 fn_ptr.1 w_md_ptr.1)

    // 4. Write character 'A' (65)
    s16: (fputc file_w_ptr.0 65 file_w_ptr.1)

    // 5. Close file
    s17: (fclose s16.0 file_w_ptr.1)

    // 6. Allocate mode "r\0"
    r_md_ptr: (malloc s17.0 4)
    s18: (store_i8 r_md_ptr.0 r_md_ptr.1 114) // 'r'
    id_r: (add64 r_md_ptr.1 1)
    s19: (store_i8 s18.0 id_r.0 0) // '\0'

    // 7. Open file for reading
    file_r_ptr: (fopen s19.0 fn_ptr.1 r_md_ptr.1)

    // 8. Read character
    c_val: (fgetc file_r_ptr.0 file_r_ptr.1)

    // 9. Close file
    s20: (fclose c_val.0 file_r_ptr.1)

    // 10. Free memory
    s21: (free s20.0 fn_ptr.1)
    s22: (free s21.0 w_md_ptr.1)
    s23: (free s22.0 r_md_ptr.1)

    // 11. Check if read character is 'A' (65)
    either (neq c_val.1 65) [
        1 // Fail
    ][
        0 // Pass
    ]
]
