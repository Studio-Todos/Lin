// RUN: %linc build %s -o %t | FileCheck %s

import "std/math.lin"

// CHECK: Parsing Source:
// CHECK: Generated MLIR

test_intrinsics: func [
    a [f32!]
    b [f64!]
    c [i32!]
    d [i64!]
    return: [i64!]
][
    sq: (fsqrt a)
    si: (fsin sq.0)
    co: (fcos si.0)
    ex: (fexp co.0)
    lo: (flog ex.0)
    ab: (fabs lo.0)
    ce: (fceil ab.0)
    fl: (ffloor ce.0)

    sq64: (fsqrt64 b)
    si64: (fsin64 sq64.0)
    co64: (fcos64 si64.0)
    ex64: (fexp64 co64.0)
    lo64: (flog64 ex64.0)
    ab64: (fabs64 lo64.0)
    ce64: (fceil64 ab64.0)
    fl64: (ffloor64 ce64.0)

    nt: (not c)
    ct: (ctlz nt.0)
    tz: (cttz ct.0)
    po: (ctpop tz.0)

    nt64: (not64 d)
    ct64: (ctlz64 nt64.0)
    tz64: (cttz64 ct64.0)
    po64: (ctpop64 tz64.0)

    po64.0
]
