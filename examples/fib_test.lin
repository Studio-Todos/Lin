import "std/math.lin"
import "std/io.lin"

fib: func [
    n [i32!]
    return: [i32!]
][
    either (lt n 2) [
        n
    ][
        (add (fib (sub n 1)) (fib (sub n 2)))
    ]
]

main: func [
    return: [i32!]
][
    state: 0
    res: (fib 10)

    either (eq res 55) [
        state: (print_i32 state 1)
    ][
        state: (print_i32 state 0)
    ]
    0
]
